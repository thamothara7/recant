# ── Core ──────────────────────────────────────────────
DATABASE_URL=postgresql://root@localhost:26257/recant?sslmode=disable
RECANT_API=http://localhost:8000

# ── Gateway ───────────────────────────────────────────
# TTL for beliefs from untrusted sources (days). Set to 90 for
# the deployed demo so nothing expires during judging.
RECANT_UNTRUSTED_TTL_DAYS=7

# ── Taint engine ──────────────────────────────────────
# Cosine similarity threshold for vector taint tracing.
# Default: the embedder's own threshold (0.35 for HashEmbedder).
# RECANT_TAINT_THRESHOLD=
RECANT_TAINT_TOP_K=20
RECANT_TAINT_MAX_K=320

# ── Fleet ─────────────────────────────────────────────
# Embedder: 'hash' (deterministic, local) or 'titan' (Bedrock, needs U3)
RECANT_EMBEDDER=hash
RECANT_GATEWAY_URL=http://localhost:8000

# ── Fanout ────────────────────────────────────────────
# Outbox poll interval in ms (250ms default, sub-second eviction)
RECANT_FANOUT_POLL_MS=250

# ── Lambda (blocked on U3) ────────────────────────────
# RECANT_EVENT_BUS=recant

# ── CORS ──────────────────────────────────────────────
# Comma-separated origins for the console to read judge-overlay headers
RECANT_CORS_ORIGINS=http://localhost:5173

# ── Cloud (never committed — gitignored) ──────────────
# DATABASE_URL_CLOUD=postgresql://recant_app:...@...

# ── Production guard ──────────────────────────────────
# Set to 'production' to block the deterministic dev signer
# RECANT_ENV=
